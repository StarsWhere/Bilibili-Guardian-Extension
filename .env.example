# 真实 LLM 集成测试配置
# 供 tests/real-llm.test.ts 使用

# OpenAI 兼容接口的 Base URL，例如：
# BILIBILI_GUARDIAN_REAL_LLM_BASE_URL=https://llm.example.com/v1
BILIBILI_GUARDIAN_REAL_LLM_BASE_URL=

# 目标服务的 API Key
BILIBILI_GUARDIAN_REAL_LLM_API_KEY=

# 要测试的模型名称，例如：
# BILIBILI_GUARDIAN_REAL_LLM_MODEL=gpt-5.4-mini
BILIBILI_GUARDIAN_REAL_LLM_MODEL=

# 扩展使用的 provider，推荐填 custom
# 可选，默认值为 custom
BILIBILI_GUARDIAN_REAL_LLM_PROVIDER=custom

# 可选，请求超时时间，单位毫秒
BILIBILI_GUARDIAN_REAL_LLM_TIMEOUT_MS=90000
