{
  "name": "bilibili-guardian-extension",
  "version": "0.1.13",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/watch-build.mjs",
    "build": "npm run build:content && npm run build:background",
    "build:all": "npm run build && npm run build:userscript",
    "build:content": "vite build --config vite.content.config.ts",
    "build:background": "vite build --config vite.background.config.ts",
    "build:userscript": "vite build --config vite.userscript.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release:prepare": "node ./scripts/prepare-release.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.306",
    "@types/node": "^24.6.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  }
}
